# Discord Webhook URL for dispatching alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Cron schedule (default is every 5 minutes: */5 * * * *)
SCRAPE_INTERVAL=*/5 * * * *

# Path where the scraper state will be stored locally
STATE_FILE_PATH=./data/state.json

# Comma-separated list of Nitter instances to query in rotation/fallback order
NITTER_INSTANCES=nitter.cz,nitter.poast.org,nitter.no-logs.otf.gg

# The public Telegram channel name to scrape (e.g. SidraChain_Official)
TELEGRAM_CHANNEL=SidraChain_Official

# Discord Webhook URL for major Roadmap & Feature updates
ROADMAP_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Optional Google Gemini API Key for auto-analysis
GEMINI_API_KEY=your-gemini-api-key

# Comma-separated list of target portal URLs to track features
ROADMAP_URLS=https://sidrachain.com
